// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Gender {
  men
  women
}

enum Season {
  summer
  winter
  all
}

model Product {
  id            Int      @id @default(autoincrement())
  name          String
  price         Float
  originalPrice Float?
  image         String
  images        String[]
  category      String
  gender        Gender
  sizes         String[]
  colors        String[]
  occasion      String?
  season        Season?  @default(all)
  isNew         Boolean  @default(false)
  description   String?
  createdAt     DateTime @default(now())

  @@index([category])
  @@index([gender])
  @@index([occasion])
}

model Category {
  id     Int    @id @default(autoincrement())
  name   String
  slug   String @unique
  image  String
  gender Gender
}

model Review {
  id        Int      @id @default(autoincrement())
  name      String
  rating    Int
  comment   String
  image     String?
  createdAt DateTime @default(now())
}

model User {
  id           Int      @id @default(autoincrement())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  orders       Order[]

  @@index([email])
}

model Order {
  id            Int         @id @default(autoincrement())
  orderId       String      @unique
  userId        Int
  user          User        @relation(fields: [userId], references: [id])
  total         Float
  shippingFee   Float       @default(0)
  paymentMethod String
  status        String      @default("Confirmed")
  firstName     String
  lastName      String
  phone         String
  pincode       String
  apt           String?
  street        String
  city          String
  state         String
  items         OrderItem[]
  createdAt     DateTime    @default(now())

  @@index([userId])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  name      String
  price     Float
  quantity  Int
  size      String?
  color     String?
  image     String

  @@index([orderId])
}
